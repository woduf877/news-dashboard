# ─── AI 에이전트 설정 ───────────────────────────────────
# 사용할 AI 제공자: gemini (기본) 또는 groq
AI_PROVIDER=gemini

# Google Gemini API 키 (무료)
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API 키 (대안, 무료)
# 발급: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ─── 서버 설정 ──────────────────────────────────────────
PORT=3001
